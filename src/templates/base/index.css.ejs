@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --brand: #3d4dff;
    --brand-hover: #2124ff;
    --brand-light: #ebf0ff;
  }

  body {
    @apply antialiased text-gray-900 bg-white;
    font-feature-settings: "cv02", "cv03", "cv04", "cv11";
  }

  h1, h2, h3, h4, h5, h6 {
    @apply tracking-tight;
  }
}

@layer components {
  .btn-primary {
    @apply px-6 py-3 bg-brand-600 text-white font-bold rounded-xl hover:bg-brand-700 active:scale-[0.98] transition-all shadow-lg shadow-brand-100 flex items-center justify-center gap-2;
  }

  .btn-secondary {
    @apply px-6 py-3 bg-white text-gray-900 border-2 border-gray-100 font-bold rounded-xl hover:bg-gray-50 active:scale-[0.98] transition-all flex items-center justify-center gap-2;
  }

  .input-field {
    @apply w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl focus:bg-white focus:ring-4 focus:ring-brand-50 focus:border-brand-600 outline-none transition-all font-medium placeholder-gray-400;
  }
}

/* Custom Scrollbar */
::-webkit-scrollbar {
  width: 10px;
}

::-webkit-scrollbar-track {
  @apply bg-transparent;
}

::-webkit-scrollbar-thumb {
  @apply bg-gray-200 rounded-full border-4 border-transparent bg-clip-content hover:bg-gray-300 transition-colors;
}
